---
import BaseLayout from '@layouts/BaseLayout.astro'
import PostCard from '@components/PostCard.astro'
import { getCollection } from 'astro:content'
import { sortAllByDate, slugifyTag, postSlug, url, type AnyPost } from '@utils'

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog')
  const draftPosts = import.meta.env.DEV ? await getCollection('drafts') : []
  const allPosts: AnyPost[] = [...blogPosts.filter(p => import.meta.env.DEV || !p.data.draft), ...draftPosts]
  const tagMap = new Map<string, { name: string; posts: AnyPost[] }>()

  for (const post of allPosts) {
    for (const tag of post.data.tags) {
      const slug = slugifyTag(tag)
      if (!tagMap.has(slug)) tagMap.set(slug, { name: tag, posts: [] })
      tagMap.get(slug)!.posts.push(post)
    }
  }

  return Array.from(tagMap.entries()).map(([slug, { name, posts }]) => ({
    params: { tag: slug },
    props: { tagName: name, posts: sortAllByDate(posts) },
  }))
}

const { tagName, posts } = Astro.props
---

<BaseLayout
  title={tagName}
  description={`All notes tagged "${tagName}".`}
  canonicalPath={`/tags/${Astro.params.tag}/`}
>
  <div style="margin-bottom: 0.5rem;">
    <a href={url('/tags/')} style="font-size: 0.875rem; color: var(--color-muted);">← All tags</a>
  </div>

  <h1 class="page-title" style="margin-top: 1rem;">{tagName}</h1>
  <p class="page-subtitle" style="margin-bottom: 2.5rem;">
    {posts.length} {posts.length === 1 ? 'post' : 'posts'}
  </p>

  <ul class="post-list">
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
        slug={postSlug(post.id)}
        tags={post.data.tags}
      />
    ))}
  </ul>
</BaseLayout>
