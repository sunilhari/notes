---
import BaseLayout from '@layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'
import { getAllTags, url } from '@utils'

const blogPosts = await getCollection('blog')
const draftPosts = import.meta.env.DEV ? await getCollection('drafts') : []
const tags = getAllTags([...blogPosts.filter(p => import.meta.env.DEV || !p.data.draft), ...draftPosts])
---

<BaseLayout title="Tags" description="Browse all topics." canonicalPath="/tags/">
  <h1 class="page-title">Tags</h1>
  <p class="page-subtitle" style="margin-bottom: 2rem;">
    Browse notes by topic.
  </p>

  {tags.length === 0 ? (
    <p style="color: var(--color-muted);">No tags yet.</p>
  ) : (
    <div>
      {tags.map(t => (
        <div class="tag-item">
          <a href={url(`/tags/${t.slug}/`)}>{t.name}</a>
          <span class="tag-count">{t.count} {t.count === 1 ? 'post' : 'posts'}</span>
        </div>
      ))}
    </div>
  )}
</BaseLayout>
