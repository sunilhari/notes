---
import BaseLayout from '@layouts/BaseLayout.astro'
---

<BaseLayout title="About" description="About me and this blog." canonicalPath="/about/">
  <h1 class="page-title">About</h1>

  <article class="prose" style="margin-top: 2rem;">
    <p>
      Hi, I'm <strong>Your Name</strong>. This is my personal blog where I write notes
      on topics I study and learn.
    </p>

    <h2>What I write about</h2>
    <p>
      I use this space to document things while I learn them — programming, computer science,
      tools, and anything else I find worth writing down. Writing helps me think more clearly
      and remember things longer.
    </p>

    <h2>About this site</h2>
    <p>
      Posts are written in Markdown and built with <a href="https://astro.build">Astro</a>.
      The design is intentionally minimal — just content, with nothing in the way.
    </p>

    <h2>Contact</h2>
    <p>
      You can reach me at <a href="mailto:you@example.com">you@example.com</a>.
    </p>
  </article>
</BaseLayout>
