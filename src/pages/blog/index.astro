---
import BaseLayout from '@layouts/BaseLayout.astro'
import PostCard from '@components/PostCard.astro'
import { getCollection } from 'astro:content'
import { sortByDate, sortAllByDate, getAllTags, slugifyTag, postSlug } from '@utils'

const blogPosts = await getCollection('blog')
const draftPosts = import.meta.env.DEV ? await getCollection('drafts') : []
const posts = sortAllByDate([...sortByDate(blogPosts), ...draftPosts])
const tags = getAllTags([...blogPosts.filter(p => import.meta.env.DEV || !p.data.draft), ...draftPosts])
---

<BaseLayout title="Blog" description="All notes and posts." canonicalPath="/blog/">
  <div style="margin-bottom: 2.5rem;">
    <h1 class="page-title">Blog</h1>
    <p class="page-subtitle">All notes, sorted newest first.</p>
  </div>

  {tags.length > 0 && (
    <div style="margin-bottom: 2.5rem;">
      <div class="section-heading">Browse by Topic</div>
      <div class="tags">
        {tags.map(t => (
          <a href={`/tags/${t.slug}/`} class="tag">
            {t.name} <span style="opacity:0.6; font-weight:400;">({t.count})</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="section-heading" style="overflow: hidden;">
    All Posts
    <span class="see-all" style="float:none; font-size: 0.8125rem; color: var(--color-muted);">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'}
    </span>
  </div>
  <ul class="post-list">
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
        slug={postSlug(post.id)}
        tags={post.data.tags}
        draft={post.data.draft}
      />
    ))}
  </ul>
</BaseLayout>
